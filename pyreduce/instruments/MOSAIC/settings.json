{
    "__instrument__": "MOSAIC",
    "__inherits__": "defaults/settings.json",
    "trace": {
        "manual": false,
        "auto_merge_threshold": 1,
        "merge_min_threshold": 0
    },
    "curvature": {
        "curve_height": 35,
        "extraction_height": 5,
        "curve_degree": 1
    },
    "wavecal_init": {
        "atlas": "thar_full",
        "medium": "vac",
        "cutoff": 0.001,
        "match_tolerance": 1.0,
        "width_max": 10.0,
        "wave_delta": 3.0
    },
    "wavecal": {
        "atlas": "thar_full",
        "dimensionality": "1D",
        "degree": 5,
        "threshold": 2000,
        "iterations": 2
    },
    "science": {
        "extraction_reject": 12,
        "oversampling": 8,
        "swath_width": 800,
        "smooth_slitfunction": 5,
        "smooth_spectrum": 1e-07
    }
}
