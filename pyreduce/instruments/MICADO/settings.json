{
    "__instrument__": "MICADO",
    "__inherits__": "defaults/settings.json",
    "flat": {
        "bias_scaling": "number_of_files"
    },
    "trace": {
        "degree": 5,
        "degree_before_merge": "best",
        "bias_scaling": "exposure_time",
        "filter_y": 300,
        "min_cluster": 2000,
        "noise": 50,
        "border_width": 5,
        "auto_merge_threshold": 0.9,
        "merge_min_threshold": 0.01,
        "manual": true,
        "min_width": 0
    },
    "scatter": {
        "bias_scaling": "number_of_files",
        "extraction_height": 0.9,
        "border_width": 20
    },
    "norm_flat": {
        "smooth_slitfunction": 1.0,
        "smooth_spectrum": 0.0,
        "extraction_height": 3500,
        "oversampling": 5,
        "swath_width": 100,
        "threshold": 1000,
        "maxiter": 30
    },
    "curvature": {
        "dimensionality": "1D",
        "degree": 1,
        "curve_degree": 1,
        "extraction_method": "simple",
        "collapse_function": "median",
        "curve_height": 700,
        "extraction_height": 100,
        "curvature_cutoff": 10,
        "peak_threshold": 10,
        "peak_width": 1,
        "window_width": 20,
        "peak_function": "gaussian",
        "bias_scaling": "exposure_time",
        "norm_scaling": "divide"
    },
    "wavecal_master": {
        "extraction_method": "optimal",
        "collapse_function": "mean",
        "extraction_height": 700.0,
        "bias_scaling": "number_of_files",
        "norm_scaling": "divide",
        "oversampling": 10,
        "swath_width": 300,
        "maxiter": 30,
        "smooth_slitfunction": 0.1,
        "smooth_spectrum": 1e-07,
        "extraction_reject": 6,
        "plot": true,
        "plot_title": "Wavelength Calibration Spectrum"
    },
    "wavecal": {
        "extraction_method": "optimal",
        "bias_scaling": "number_of_files",
        "threshold": 80,
        "iterations": 3,
        "dimensionality": "2D",
        "extraction_height": 700,
        "degree": [
            5,
            5
        ],
        "manual": true,
        "shift_window": 0.1
    },
    "science": {
        "extraction_method": "optimal",
        "extraction_height": null,
        "oversampling": 10,
        "swath_width": 300,
        "maxiter": 30,
        "smooth_slitfunction": 0.1,
        "smooth_spectrum": 1e-07,
        "extraction_reject": 6,
        "bias_scaling": "number_of_files",
        "norm_scaling": "divide",
        "plot": true,
        "plot_title": "Science Data"
    }
}
